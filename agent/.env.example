# ============================================================================
# SVGM agent runtime — Foundry-compatible env file
# ============================================================================
# Copy to `.env` and fill in. NEVER commit a real `.env`.

# Required: EOA private key used for deploy + mint (hex, with or without 0x).
PRIVATE_KEY=

# Optional: choose the network. Defaults to Pharos mainnet.
#   PHAROS_RPC_URL=https://rpc.pharos.xyz           # mainnet (chain 1672)
#   PHAROS_RPC_URL=https://atlantic.dplabs-internal.com  # testnet (chain 688688)
PHAROS_RPC_URL=https://rpc.pharos.xyz
CHAIN_ID=1672
EXPLORER_URL=https://pharosscan.xyz

# Optional tuning.
GAS_LIMIT_BUFFER=120
SVG_MAX_BYTES=24576

# Optional: path to the Foundry build artifact for OnchainSVG.
#   Default: ../out/OnchainSVG.sol/OnchainSVG.json (relative to agent/)
#   Set this if you build into a different directory.
# FORGE_ARTIFACT_PATH=../out/OnchainSVG.sol/OnchainSVG.json
