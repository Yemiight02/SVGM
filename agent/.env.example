# Required — EOA private key used to deploy and mint (hex, with or without 0x prefix).
PRIVATE_KEY=

# Optional — defaults to Pharos mainnet.
#   mainnet  : Pharos Mainnet       (chain id 1672,  https://rpc.pharos.xyz)
#   testnet  : Pharos Atlantic      (chain id 688688, https://atlantic.dplabs-internal.com)
PHAROS_RPC_URL=https://rpc.pharos.xyz
CHAIN_ID=1672
EXPLORER_URL=https://pharosscan.xyz

# Optional — fine tuning.
GAS_LIMIT_BUFFER=120
SVG_MAX_BYTES=24576
